# Build stage
FROM node:18-alpine AS build

WORKDIR /app

# Copy package files
COPY client-eco-track/package*.json ./

# Install dependencies
RUN npm ci

# Copy source code
COPY client-eco-track . 

# Build application
RUN npm run build

# Production stage
FROM node:18-alpine

WORKDIR /app

# Install serve to run the app
RUN npm install -g serve

# Copy built files from build stage
COPY --from=build /app/dist ./dist

EXPOSE 3000

CMD ["serve", "-s", "dist", "-l", "3000"]
